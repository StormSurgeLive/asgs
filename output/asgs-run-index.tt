<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>[% title | html %]</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      background: #ffffff;
      color: #000000;
      font-family: Verdana, Arial, Helvetica, sans-serif;
      font-size: 13px;
      line-height: 1.25;
    }

    a {
      color: #000099;
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    .page {
      width: 100%;
      margin: 0;
      padding: 0 0 2rem 0;
    }

    .phpinfo-header {
      background: linear-gradient(#6f7fb7, #4d5f98);
      color: #ffffff;
      padding: 12px 18px;
      border-bottom: 1px solid #2b3d78;
      box-shadow: inset 0 -1px 0 rgba(255,255,255,0.15);
    }

    .phpinfo-header h1 {
      margin: 0;
      font-size: 28px;
      font-weight: bold;
      letter-spacing: 0.2px;
    }

    .phpinfo-header .subline {
      margin-top: 5px;
      font-size: 12px;
      color: #edf2ff;
    }

    .toolbar {
      padding: 8px 18px;
      background: #f2f3f7;
      border-bottom: 1px solid #c7ccda;
      color: #333333;
      font-size: 12px;
    }

    .toolbar .right {
      float: right;
    }

    .toolbar::after {
      content: "";
      display: block;
      clear: both;
    }

    .section {
      margin: 14px 12px 0 12px;
      border: 1px solid #c7ccda;
      background: #ffffff;
    }

    .section h2 {
      margin: 0;
      padding: 6px 10px;
      font-size: 18px;
      color: #000000;
      background: linear-gradient(#cfd6ec, #b8c3e3);
      border-bottom: 1px solid #a8b5d8;
    }

    .section-body {
      padding: 8px 10px;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 8px;
    }

    .summary-card {
      border: 1px solid #c7ccda;
      background: #f8f9fc;
    }

    .summary-card h3 {
      margin: 0;
      padding: 5px 8px;
      font-size: 14px;
      background: #dfe5f4;
      border-bottom: 1px solid #c7ccda;
      color: #000000;
    }

    .summary-card .body {
      padding: 7px 8px;
    }

    .badge,
    .badge-link {
      display: inline-block;
      margin: 0 4px 4px 0;
      padding: 1px 6px;
      font-size: 11px;
      line-height: 1.35;
      border: 1px solid #aab7d9;
      background: #eef2fb;
      color: #1d2d5a;
      border-radius: 2px;
      white-space: nowrap;
      vertical-align: middle;
    }

    .badge-link {
      color: #000099;
      text-decoration: none;
    }

    .badge-link:hover {
      text-decoration: underline;
    }

    .badge-ok {
      background: #e7f7e7;
      border-color: #9bc79b;
      color: #1f5c1f;
    }

    .badge-warn {
      background: #fff7d6;
      border-color: #d8c46c;
      color: #755e00;
    }

    .badge-bad {
      background: #fdeaea;
      border-color: #d79d9d;
      color: #8a1f1f;
    }

    .badge-neutral {
      background: #f0f0f0;
      border-color: #cccccc;
      color: #555555;
    }

    .legend {
      margin: 0 0 8px 0;
      padding: 6px 8px;
      border: 1px solid #d4d9e6;
      background: #f8f9fc;
      font-size: 11px;
      color: #333333;
    }

    .legend .label {
      display: inline-block;
      margin-right: 6px;
      font-weight: bold;
      color: #444444;
    }

    .jump-links {
      line-height: 1.6;
    }

    .jump-links a {
      display: inline-block;
      margin: 0 6px 5px 0;
      padding: 1px 6px;
      border: 1px solid #bac5e0;
      background: #eef2fb;
      color: #000099;
      font-size: 11px;
    }

    .netcdf-pills a {
      display: inline-block;
      margin: 0 4px 4px 0;
      padding: 1px 6px;
      border: 1px solid #bac5e0;
      background: #eef2fb;
      color: #000099;
      font-size: 11px;
    }

    .netcdf-pills a.ok {
      background: #e7f7e7;
      border-color: #9bc79b;
      color: #1f5c1f;
    }

    .netcdf-pills a.mismatch {
      background: #fdeaea;
      border-color: #d79d9d;
      color: #8a1f1f;
    }

    .netcdf-pills a.unknown {
      background: #f0f0f0;
      border-color: #cccccc;
      color: #555555;
    }

    table.info {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      font-size: 12px;
    }

    table.info th,
    table.info td {
      border: 1px solid #c7ccda;
      padding: 4px 6px;
      vertical-align: top;
      word-wrap: break-word;
    }

    table.info th {
      width: 28%;
      background: #dfe5f4;
      color: #000000;
      text-align: left;
      font-weight: bold;
    }

    table.info td {
      background: #ffffff;
      color: #000000;
    }

    table.listing {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }

    table.listing th,
    table.listing td {
      border: 1px solid #c7ccda;
      padding: 3px 6px;
      text-align: left;
      vertical-align: top;
    }

    table.listing th {
      background: #dfe5f4;
      color: #000000;
      font-weight: bold;
    }

    table.listing tr:nth-child(even) td {
      background: #f8f9fc;
    }

    code, pre {
      font-family: Consolas, "Courier New", monospace;
      font-size: 12px;
    }

    code {
      color: #7a1f1f;
    }

    pre {
      margin: 6px 0 0 0;
      padding: 7px;
      background: #f7f7fb;
      border: 1px solid #d5d9e7;
      overflow-x: auto;
      white-space: pre-wrap;
    }

    details {
      margin-top: 3px;
    }

    summary {
      cursor: pointer;
      color: #000099;
      font-size: 11px;
    }

    .muted {
      color: #666666;
    }

    .small {
      font-size: 12px;
    }

    .good {
      color: #1f5c1f;
      font-weight: bold;
    }

    .bad {
      color: #8a1f1f;
      font-weight: bold;
    }

    .warn {
      color: #755e00;
      font-weight: bold;
    }

    .anchor-offset {
      scroll-margin-top: 14px;
    }

    .footer-note {
      margin: 14px 12px 0 12px;
      padding: 8px 10px;
      border: 1px solid #c7ccda;
      background: #f8f9fc;
      color: #444444;
      font-size: 12px;
    }

    .file-name-cell {
      min-width: 220px;
      max-width: 320px;
    }

    .file-name-main {
      display: inline;
    }

    .file-badge-row {
      display: inline;
      margin-left: 6px;
    }

    .file-badge-row .badge {
      margin-bottom: 2px;
    }

    .meta-toggle {
      display: block;
      margin-top: 3px;
    }

    .compact-col-xs { width: 58px; }
    .compact-col-sm { width: 72px; }
    .compact-col-md { width: 92px; }
    .compact-col-lg { width: 118px; }
    .compact-col-date { width: 150px; }

    ul.compact-list {
      margin: 4px 0 4px 16px;
      padding: 0;
    }

    ul.compact-list li {
      margin: 1px 0;
    }
  </style>
</head>
<body>
<div class="page">

  <div class="phpinfo-header">
    <h1>[% title | html %]</h1>
    <div class="subline">
      Generated: [% generated_at | html %]
      &nbsp;|&nbsp;
      <a href="[% brand.link | html %]" style="color:#ffffff; text-decoration:underline;">[% brand.text | html %]</a>
    </div>
  </div>

  <div class="toolbar">
    <span><strong>Mode:</strong> [% source.mode | html %]</span>
    <span class="right"><strong>Download base:</strong> <a href="[% source.base_url | html %]">[% source.base_url | html %]</a></span>
  </div>

  <div class="section">
    <h2>Source</h2>
    <div class="section-body">
      <table class="info">
        <tr>
          <th>SSH host</th>
          <td><code>[% source.ssh_host | html %]</code></td>
        </tr>
        <tr>
          <th>Remote path</th>
          <td><code>[% source.remote_path | html %]</code></td>
        </tr>
        [% IF source.local_dir %]
        <tr>
          <th>Local dir</th>
          <td><code>[% source.local_dir | html %]</code></td>
        </tr>
        [% END %]
        <tr>
          <th>Download base</th>
          <td><a href="[% source.base_url | html %]">[% source.base_url | html %]</a></td>
        </tr>
        <tr>
          <th>Deploy target</th>
          <td><code>[% source.deploy_target | html %]</code></td>
        </tr>
      </table>
    </div>
  </div>

  <div class="section">
    <h2>Navigation</h2>
    <div class="section-body">
      <div class="jump-links">
        <a href="#inventory-summary">Inventory summary</a>
        <a href="#expected-output-summary">Expected output summary</a>
        <a href="#record-check-summary">NetCDF record checks</a>
        <a href="#run-summary">Run summary</a>
        <a href="#fort14-summary">fort.14</a>
        <a href="#fort15-summary">fort.15</a>
        <a href="#asgs-config-summary">ASGS config</a>
        <a href="#build-metadata">Build metadata</a>
        <a href="#adcirc-input-files">ADCIRC input files</a>
        <a href="#adcirc-output-files">ADCIRC output files</a>
        <a href="#other-files">Other files</a>
      </div>

      [% IF grouped.adcirc_output.size %]
      <div style="margin-top:8px;">
        <div class="legend">
          <span class="label">Legend:</span>
          <span class="badge badge-ok">OK</span>
          <span class="badge badge-bad">Mismatch</span>
          <span class="badge badge-neutral">Unknown</span>
          <span class="badge badge-ok">expected</span>
          <span class="badge badge-warn">published-only</span>
        </div>
        <div class="small" style="margin-bottom:5px;"><strong>NetCDF quick jump</strong></div>
        <div class="netcdf-pills">
          [% FOREACH f IN grouped.adcirc_output %]
            [% css_class = '' %]
            [% IF f.record_check == 'ok' %]
              [% css_class = 'ok' %]
            [% ELSIF f.record_check == 'mismatch' %]
              [% css_class = 'mismatch' %]
            [% ELSIF f.record_check == 'unknown' %]
              [% css_class = 'unknown' %]
            [% END %]
            <a class="[% css_class %]" href="#nc-[% f.name | replace('.', '-') | replace('/', '-') | html %]">
              [% f.name | html %]
              [% IF f.record_check == 'ok' %] ✓[% END %]
              [% IF f.record_check == 'mismatch' %] ✕[% END %]
              [% IF f.record_check == 'unknown' %] ?[% END %]
            </a>
          [% END %]
        </div>
      </div>
      [% END %]
    </div>
  </div>

  <div class="section anchor-offset" id="inventory-summary">
    <h2>Inventory summary</h2>
    <div class="section-body">
      <div class="legend">
        <span class="label">Legend:</span>
        <span class="badge badge-ok">OK</span>
        <span class="badge badge-bad">Mismatch</span>
        <span class="badge badge-neutral">Unknown</span>
        <span class="badge badge-ok">Published expected</span>
        <span class="badge badge-bad">Missing expected</span>
        <span class="badge badge-warn">Unexpected published</span>
      </div>

      <div class="summary-grid">
        <div class="summary-card">
          <h3>Inventory</h3>
          <div class="body">
            <span class="badge">Files: [% totals.file_count %]</span>
            <span class="badge">NetCDF: [% totals.netcdf_count %]</span>
            <span class="badge">Total size: [% totals.bytes_total_human %]</span>
          </div>
        </div>

        <div class="summary-card">
          <h3>Breakdown</h3>
          <div class="body">
            <span class="badge">Input: [% totals.input_count %]</span>
            <span class="badge">Output: [% totals.output_count %]</span>
            <span class="badge">Other: [% totals.other_count %]</span>
          </div>
        </div>

        <div class="summary-card">
          <h3>NetCDF checks</h3>
          <div class="body">
            <span class="badge badge-ok">OK: [% totals.record_check_ok_count %]</span>
            <span class="badge badge-bad">Mismatch: [% totals.record_check_mismatch_count %]</span>
            <span class="badge badge-neutral">Unknown: [% totals.record_check_unknown_count %]</span>
            <span class="badge">Summed records: [% totals.netcdf_record_total %]</span>
          </div>
        </div>

        <div class="summary-card">
          <h3>Expected output tracking</h3>
          <div class="body">
            <span class="badge">Expected outputs: [% totals.expected_output_count %]</span>
            <span class="badge badge-ok">Published expected: [% totals.published_expected_count %]</span>
            <span class="badge [% IF totals.missing_expected_count %]badge-bad[% ELSE %]badge-ok[% END %]">
              Missing expected: [% totals.missing_expected_count %]
            </span>
            <span class="badge [% IF totals.unexpected_output_count %]badge-warn[% ELSE %]badge-ok[% END %]">
              Unexpected published: [% totals.unexpected_output_count %]
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="section anchor-offset" id="expected-output-summary">
    <h2>Expected output summary</h2>
    <div class="section-body">

      <div class="legend">
        <span class="label">Legend:</span>
        <span class="badge badge-bad">Missing expected</span>
        <span class="badge badge-warn">Published but not explicitly declared</span>
      </div>

      [% IF expected_outputs.size %]
      <details>
        <summary>Show expected output filenames from <code>run.properties</code> ([% expected_outputs.size %])</summary>
        <pre>[% FOREACH name IN expected_outputs %][% name | html %]
[% END %]</pre>
      </details>
      [% END %]

      [% IF missing_expected.size %]
      <h3 class="bad" style="margin:10px 0 6px 0;">Missing expected outputs</h3>
      <table class="listing">
        <thead>
          <tr>
            <th>Expected file</th>
            <th class="compact-col-md">Expected records</th>
            <th>Reason</th>
          </tr>
        </thead>
        <tbody>
        [% FOREACH item IN missing_expected %]
          <tr>
            <td><code>[% item.name | html %]</code></td>
            <td>[% item.expected_records || '' %]</td>
            <td>[% item.reason | html %]</td>
          </tr>
        [% END %]
        </tbody>
      </table>
      [% ELSE %]
      <div class="good">No expected outputs are missing from the published directory.</div>
      [% END %]

      [% IF unexpected_outputs.size %]
      <h3 class="warn" style="margin:10px 0 6px 0;">Published outputs not explicitly declared in <code>run.properties</code></h3>
      <table class="listing">
        <thead>
          <tr>
            <th>Published file</th>
            <th class="compact-col-md">Size</th>
            <th class="compact-col-date">Modified</th>
            <th class="compact-col-sm">Download</th>
          </tr>
        </thead>
        <tbody>
        [% FOREACH f IN unexpected_outputs %]
          <tr>
            <td><code>[% f.name | html %]</code></td>
            <td>[% f.size_human | html %]</td>
            <td>[% f.mtime_iso | html %]</td>
            <td><a href="[% f.url | html %]">download</a></td>
          </tr>
        [% END %]
        </tbody>
      </table>
      [% END %]

    </div>
  </div>

  [% IF record_mismatches.size || record_unknown.size %]
  <div class="section anchor-offset" id="record-check-summary">
    <h2>NetCDF record checks</h2>
    <div class="section-body">

      <div class="legend">
        <span class="label">Legend:</span>
        <span class="badge badge-bad">Mismatch</span>
        <span class="badge badge-neutral">Unknown</span>
      </div>

      [% IF record_mismatches.size %]
      <h3 class="bad" style="margin:0 0 6px 0;">Mismatches</h3>
      <table class="listing">
        <thead>
          <tr>
            <th>File</th>
            <th class="compact-col-sm">Actual</th>
            <th class="compact-col-md">Expected</th>
            <th class="compact-col-sm">Download</th>
          </tr>
        </thead>
        <tbody>
        [% FOREACH f IN record_mismatches %]
          <tr>
            <td><code>[% f.name | html %]</code></td>
            <td>
              [% IF f.nc && !f.nc.error %]
                [% f.nc.record_count || '' %]
              [% ELSE %]
                error
              [% END %]
            </td>
            <td>[% f.expected_records || '' %]</td>
            <td><a href="[% f.url | html %]">download</a></td>
          </tr>
        [% END %]
        </tbody>
      </table>
      [% END %]

      [% IF record_unknown.size %]
      <h3 class="warn" style="margin:10px 0 6px 0;">Unknown checks</h3>
      <table class="listing">
        <thead>
          <tr>
            <th>File</th>
            <th>Reason</th>
            <th class="compact-col-sm">Download</th>
          </tr>
        </thead>
        <tbody>
        [% FOREACH f IN record_unknown %]
          <tr>
            <td><code>[% f.name | html %]</code></td>
            <td>
              [% IF f.nc && f.nc.error %]
                <details>
                  <summary>ncdump error</summary>
                  <pre>[% f.nc.error | html %]</pre>
                </details>
              [% ELSE %]
                expected count exists, actual record count unavailable
              [% END %]
            </td>
            <td><a href="[% f.url | html %]">download</a></td>
          </tr>
        [% END %]
        </tbody>
      </table>
      [% END %]

    </div>
  </div>
  [% END %]

  [% IF run_properties.key_count %]
  <div class="section anchor-offset" id="run-summary">
    <h2>Run summary</h2>
    <div class="section-body">
      <table class="info">
        [% FOREACH k IN run_properties.summary.keys.sort %]
        <tr>
          <th><code>[% k | html %]</code></th>
          <td>[% run_properties.summary.$k | html %]</td>
        </tr>
        [% END %]
      </table>

      [% IF run_properties.output_keys.size %]
      <details>
        <summary>Show all <code>adcirc.file.output.*</code> keys from <code>run.properties</code></summary>
        <pre>[% FOREACH k IN run_properties.output_keys %][% k | html %] = [% run_properties.all_keys_anon.$k | html %]
[% END %]</pre>
      </details>
      [% END %]
    </div>
  </div>
  [% END %]

  [% IF fort14.title || fort14.raw_header2 %]
  <div class="section anchor-offset" id="fort14-summary">
    <h2>fort.14 summary</h2>
    <div class="section-body">
      <table class="info">
        <tr>
          <th>Title</th>
          <td>[% fort14.title | html %]</td>
        </tr>
        <tr>
          <th>Header line 2</th>
          <td><code>[% fort14.raw_header2 | html %]</code></td>
        </tr>
        [% IF fort14.ne || fort14.np %]
        <tr>
          <th>Mesh counts</th>
          <td>
            <span class="badge">Elements: [% fort14.ne %]</span>
            <span class="badge">Nodes: [% fort14.np %]</span>
          </td>
        </tr>
        [% END %]
      </table>
    </div>
  </div>
  [% END %]

  [% IF fort15.line_count %]
  <div class="section anchor-offset" id="fort15-summary">
    <h2>fort.15 summary</h2>
    <div class="section-body">
      <table class="info">
        <tr>
          <th>Line count</th>
          <td>[% fort15.line_count %]</td>
        </tr>
      </table>

      [% IF fort15.preview_lines.size %]
      <details open>
        <summary>Preview</summary>
        <pre>[% FOREACH line IN fort15.preview_lines %][% line | html %]
[% END %]</pre>
      </details>
      [% END %]
    </div>
  </div>
  [% END %]

  [% IF asgs_config.filename %]
  <div class="section anchor-offset" id="asgs-config-summary">
    <h2>ASGS config summary</h2>
    <div class="section-body">
      <table class="info">
        <tr>
          <th>Config file</th>
          <td><code>[% asgs_config.filename | html %]</code></td>
        </tr>
      </table>

      [% IF asgs_config.summary.keys.size %]
      <table class="info" style="margin-top:8px;">
        [% FOREACH k IN asgs_config.summary.keys.sort %]
        <tr>
          <th><code>[% k | html %]</code></th>
          <td>[% asgs_config.summary.$k | html %]</td>
        </tr>
        [% END %]
      </table>
      [% END %]

      [% IF asgs_config.preview.size %]
      <details>
        <summary>Preview</summary>
        <pre>[% FOREACH line IN asgs_config.preview %][% line | html %]
[% END %]</pre>
      </details>
      [% END %]
    </div>
  </div>
  [% END %]

  [% IF buildinfo && buildinfo.keys.size %]
  <div class="section anchor-offset" id="build-metadata">
    <h2>ADCIRC build metadata</h2>
    <div class="section-body">
      <table class="info">
        [% FOREACH k IN buildinfo.keys.sort %]
          [% NEXT IF k == "adcirc.build.actualflags.info" %]
          <tr>
            <th><code>[% k | html %]</code></th>
            <td>
              [% v = buildinfo.item(k) %]
              [% IF v.search('^(HASH|ARRAY)\\(') %]
                <span class="muted">structured value</span>
              [% ELSE %]
                [% v | html %]
              [% END %]
            </td>
          </tr>
        [% END %]
      </table>

      [% build_stages = buildinfo.item('adcirc.build.actualflags.info') %]
      [% IF build_stages && build_stages.size %]
      <h3 style="margin:10px 0 6px 0;">Build stages</h3>
      <table class="listing">
        <thead>
          <tr>
            <th>Stage</th>
            <th class="compact-col-lg">Compiler</th>
            <th class="compact-col-date">Datestamp</th>
          </tr>
        </thead>
        <tbody>
        [% FOREACH item IN build_stages %]
          <tr>
            <td>[% item.stage | html %]</td>
            <td>[% item.compiler | html %]</td>
            <td>[% item.datestamp | html %]</td>
          </tr>
        [% END %]
        </tbody>
      </table>
      [% END %]
    </div>
  </div>
  [% END %]

  <div class="section anchor-offset" id="adcirc-input-files">
    <h2>ADCIRC input files</h2>
    <div class="section-body" style="padding:0;">
      <table class="listing">
        <thead>
          <tr>
            <th>Name</th>
            <th class="compact-col-md">Size</th>
            <th class="compact-col-date">Modified</th>
            <th class="compact-col-sm">Download</th>
          </tr>
        </thead>
        <tbody>
        [% FOREACH f IN grouped.adcirc_input %]
          <tr>
            <td><code>[% f.name | html %]</code></td>
            <td>[% f.size_human | html %]</td>
            <td>[% f.mtime_iso | html %]</td>
            <td><a href="[% f.url | html %]">download</a></td>
          </tr>
        [% END %]
        </tbody>
      </table>
    </div>
  </div>

  <div class="section anchor-offset" id="adcirc-output-files">
    <h2>ADCIRC output files</h2>
    <div class="section-body" style="padding:0;">
      <div style="padding:8px 10px 0 10px;">
        <div class="legend">
          <span class="label">Legend:</span>
          <span class="badge badge-ok">expected</span>
          <span class="badge badge-warn">published-only</span>
          <span class="badge badge-ok">OK</span>
          <span class="badge badge-bad">Mismatch</span>
          <span class="badge badge-neutral">Unknown</span>
        </div>
      </div>

      <table class="listing">
        <thead>
          <tr>
            <th>Name</th>
            <th class="compact-col-sm">Expected</th>
            <th class="compact-col-md">Size</th>
            <th class="compact-col-date">Modified</th>
            <th class="compact-col-sm">Actual</th>
            <th class="compact-col-md">Expected recs</th>
            <th class="compact-col-md">Check</th>
            <th class="compact-col-xs">Dims</th>
            <th class="compact-col-xs">Vars</th>
            <th class="compact-col-sm">Download</th>
          </tr>
        </thead>
        <tbody>
        [% FOREACH f IN grouped.adcirc_output %]
          <tr>
            <td class="file-name-cell" id="nc-[% f.name | replace('.', '-') | replace('/', '-') | html %]">
              <span class="file-name-main"><code>[% f.name | html %]</code></span>
              <span class="file-badge-row">
                [% IF f.is_expected_output %]
                  <span class="badge badge-ok">expected</span>
                [% ELSE %]
                  <span class="badge badge-warn">published-only</span>
                [% END %]

                [% IF f.record_check == 'mismatch' %]
                  <span class="badge badge-bad">Mismatch</span>
                [% ELSIF f.record_check == 'unknown' %]
                  <span class="badge badge-neutral">Unknown</span>
                [% ELSIF f.record_check == 'ok' %]
                  <span class="badge badge-ok">OK</span>
                [% END %]
              </span>

              [% IF f.nc && !f.nc.error %]
                <details class="meta-toggle">
                  <summary>metadata</summary>
                  <div class="small">
                    [% IF f.nc.source %]
                    <p><strong>Metadata source:</strong> [% f.nc.source | html %]</p>
                    [% END %]
                    [% IF f.nc.local_file %]
                    <p><strong>Local file:</strong> <code>[% f.nc.local_file | html %]</code></p>
                    [% END %]
                    <p><strong>Time dimension:</strong> [% f.nc.time_dim | html %]</p>

                    <p><strong>Dimensions:</strong></p>
                    <ul class="compact-list">
                    [% FOREACH d IN f.nc.dimensions.keys.sort %]
                      <li>
                        <code>[% d | html %]</code> =
                        [% f.nc.dimensions.$d.size %]
                        [% IF f.nc.dimensions.$d.unlimited %](unlimited)[% END %]
                      </li>
                    [% END %]
                    </ul>

                    <p><strong>Variables:</strong></p>
                    <ul class="compact-list">
                    [% FOREACH v IN f.nc.variables %]
                      <li>
                        <code>[% v.name | html %]</code>
                        ([% v.dims.join(', ') | html %])
                      </li>
                    [% END %]
                    </ul>
                  </div>
                </details>
              [% ELSIF f.nc && f.nc.error %]
                <details class="meta-toggle">
                  <summary>metadata error</summary>
                  <pre>[% f.nc.error | html %]</pre>
                </details>
              [% END %]
            </td>
            <td>[% IF f.is_expected_output %]<span class="good">yes</span>[% ELSE %]<span class="warn">no</span>[% END %]</td>
            <td>[% f.size_human | html %]</td>
            <td>[% f.mtime_iso | html %]</td>
            <td>
              [% IF f.nc && !f.nc.error %]
                [% f.nc.record_count || '' %]
              [% ELSIF f.nc && f.nc.error %]
                <span class="bad">error</span>
              [% END %]
            </td>
            <td>[% f.expected_records || '' %]</td>
            <td>
              [% IF f.record_check == 'ok' %]
                <span class="good">OK</span>
              [% ELSIF f.record_check == 'mismatch' %]
                <span class="bad">Mismatch</span>
              [% ELSIF f.record_check == 'unknown' %]
                <span class="warn">Unknown</span>
              [% END %]
            </td>
            <td>[% IF f.nc && !f.nc.error %][% f.nc.dimension_count %][% END %]</td>
            <td>[% IF f.nc && !f.nc.error %][% f.nc.variable_count %][% END %]</td>
            <td><a href="[% f.url | html %]">download</a></td>
          </tr>
        [% END %]
        </tbody>
      </table>
    </div>
  </div>

  [% IF grouped.other.size %]
  <div class="section anchor-offset" id="other-files">
    <h2>Other files</h2>
    <div class="section-body" style="padding:0;">
      <table class="listing">
        <thead>
          <tr>
            <th>Name</th>
            <th class="compact-col-md">Size</th>
            <th class="compact-col-date">Modified</th>
            <th class="compact-col-sm">Download</th>
          </tr>
        </thead>
        <tbody>
        [% FOREACH f IN grouped.other %]
          <tr>
            <td><code>[% f.name | html %]</code></td>
            <td>[% f.size_human | html %]</td>
            <td>[% f.mtime_iso | html %]</td>
            <td><a href="[% f.url | html %]">download</a></td>
          </tr>
        [% END %]
        </tbody>
      </table>
    </div>
  </div>
  [% END %]

  <div class="footer-note">
    This page intentionally borrows the visual feel of a traditional <code>phpinfo()</code> report:
    blue section headers, compact system-style tables, and dense at-a-glance diagnostics.
  </div>

</div>
</body>
</html>
