<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>[% title | html %]</title>
  <style>
    body { margin: 0; padding: 0; background: #ffffff; color: #000000; font-family: Verdana, Arial, Helvetica, sans-serif; font-size: 13px; line-height: 1.25; }
    a { color: #000099; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .page { width: 100%; margin: 0; padding: 0 0 2rem 0; }
    .phpinfo-header { background: linear-gradient(#6f7fb7, #4d5f98); color: #ffffff; padding: 12px 18px; border-bottom: 1px solid #2b3d78; box-shadow: inset 0 -1px 0 rgba(255,255,255,0.15); }
    .header-flex { display: flex; align-items: center; justify-content: space-between; gap: 14px; }
    .header-mark { flex: 0 0 auto; }
    .header-mark img { display: block; max-width: 100%; height: auto; border: 1px solid rgba(255,255,255,0.35); background: rgba(255,255,255,0.08); padding: 2px; }
    .phpinfo-header h1 { margin: 0; font-size: 28px; font-weight: bold; letter-spacing: 0.2px; }
    .phpinfo-header .subline { margin-top: 5px; font-size: 12px; color: #edf2ff; }
    .toolbar { padding: 8px 18px; background: #f2f3f7; border-bottom: 1px solid #c7ccda; color: #333333; font-size: 12px; }
    .toolbar .right { float: right; }
    .toolbar::after { content: ""; display: block; clear: both; }
    .section { margin: 14px 12px 0 12px; border: 1px solid #c7ccda; background: #ffffff; }
    .section h2 { margin: 0; padding: 6px 10px; font-size: 18px; color: #000000; background: linear-gradient(#cfd6ec, #b8c3e3); border-bottom: 1px solid #a8b5d8; }
    .section h3 { font-size: 14px; }
    .section-body { padding: 8px 10px; }
    .health-hero { margin: 14px 12px 0 12px; border: 1px solid #c7ccda; background: #ffffff; }
    .health-hero-head { padding: 6px 10px; font-size: 18px; color: #000000; background: linear-gradient(#cfd6ec, #b8c3e3); border-bottom: 1px solid #a8b5d8; }
    .health-banner { padding: 8px 10px; border-bottom: 1px solid #d4d9e6; background: #f8f9fc; }
    .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 8px; }
    .summary-card { border: 1px solid #c7ccda; background: #f8f9fc; }
    .summary-card h3 { margin: 0; padding: 5px 8px; font-size: 14px; background: #dfe5f4; border-bottom: 1px solid #c7ccda; color: #000000; }
    .summary-card .body { padding: 7px 8px; }
    .badge, .badge-link { display: inline-block; margin: 0 4px 4px 0; padding: 1px 6px; font-size: 11px; line-height: 1.35; border: 1px solid #aab7d9; background: #eef2fb; color: #1d2d5a; border-radius: 2px; white-space: nowrap; vertical-align: middle; }
    .badge-link { color: #000099; text-decoration: none; }
    .badge-link:hover { text-decoration: underline; }
    .badge-ok { background: #e7f7e7; border-color: #9bc79b; color: #1f5c1f; }
    .badge-warn { background: #fff7d6; border-color: #d8c46c; color: #755e00; }
    .badge-bad { background: #fdeaea; border-color: #d79d9d; color: #8a1f1f; }
    .badge-neutral { background: #f0f0f0; border-color: #cccccc; color: #555555; }
    .legend { margin: 0 0 8px 0; padding: 6px 8px; border: 1px solid #d4d9e6; background: #f8f9fc; font-size: 11px; color: #333333; }
    .legend .label { display: inline-block; margin-right: 6px; font-weight: bold; color: #444444; }
    .jump-links { line-height: 1.6; }
    .jump-links a { display: inline-block; margin: 0 6px 5px 0; padding: 1px 6px; border: 1px solid #bac5e0; background: #eef2fb; color: #000099; font-size: 11px; }
    .netcdf-pills a { display: inline-block; margin: 0 4px 4px 0; padding: 1px 6px; border: 1px solid #bac5e0; background: #eef2fb; color: #000099; font-size: 11px; }
    .netcdf-pills a.ok { background: #e7f7e7; border-color: #9bc79b; color: #1f5c1f; }
    .netcdf-pills a.mismatch { background: #fdeaea; border-color: #d79d9d; color: #8a1f1f; }
    .netcdf-pills a.unknown { background: #f0f0f0; border-color: #cccccc; color: #555555; }
    table.info { width: 100%; border-collapse: collapse; table-layout: fixed; font-size: 12px; }
    table.info th, table.info td { border: 1px solid #c7ccda; padding: 4px 6px; vertical-align: top; word-wrap: break-word; }
    table.info th { width: 28%; background: #dfe5f4; color: #000000; text-align: left; font-weight: bold; }
    table.info td { background: #ffffff; color: #000000; }
    table.listing { width: 100%; border-collapse: collapse; font-size: 12px; }
    table.listing th, table.listing td { border: 1px solid #c7ccda; padding: 3px 6px; text-align: left; vertical-align: top; }
    table.listing th { background: #dfe5f4; color: #000000; font-weight: bold; }
    table.listing tr:nth-child(even) td { background: #f8f9fc; }
    code, pre { font-family: Consolas, "Courier New", monospace; font-size: 12px; }
    code { color: #7a1f1f; }
    pre { margin: 6px 0 0 0; padding: 7px; background: #f7f7fb; border: 1px solid #d5d9e7; overflow-x: auto; white-space: pre-wrap; }
    details { margin-top: 3px; }
    summary { cursor: pointer; color: #000099; font-size: 11px; }
    .muted { color: #666666; }
    .small { font-size: 12px; }
    .good { color: #1f5c1f; font-weight: bold; }
    .bad { color: #8a1f1f; font-weight: bold; }
    .warn { color: #755e00; font-weight: bold; }
    .anchor-offset { scroll-margin-top: 14px; }
    .footer-note { margin: 14px 12px 0 12px; padding: 8px 10px; border: 1px solid #c7ccda; background: #f8f9fc; color: #444444; font-size: 12px; }
    .file-name-cell { min-width: 220px; max-width: 320px; }
    .file-name-main { display: inline; }
    .file-badge-row { display: inline; margin-left: 6px; }
    .file-badge-row .badge { margin-bottom: 2px; }
    .meta-toggle { display: block; margin-top: 3px; }
    .compact-col-xs { width: 58px; }
    .compact-col-sm { width: 72px; }
    .compact-col-md { width: 92px; }
    .compact-col-lg { width: 118px; }
    .compact-col-date { width: 150px; }
    ul.compact-list { margin: 4px 0 4px 16px; padding: 0; }
    ul.compact-list li { margin: 1px 0; }
  </style>
</head>
<body>
<div class="page">
  <div class="phpinfo-header">
    <div class="header-flex">
      <div>
        <h1>[% title | html %]</h1>
        <div class="subline">
          Generated: [% generated_at | html %]
          &nbsp;|&nbsp;
          <a href="[% brand.link | html %]" style="color:#ffffff; text-decoration:underline;">[% brand.text | html %]</a>
        </div>
      </div>
      [% IF ui.header_image.url %]
      <div class="header-mark">
        <a href="[% ui.header_image.link | html %]" target="_blank" rel="noopener noreferrer">
          <img src="[% ui.header_image.url | html %]" alt="[% ui.header_image.alt | html %]" width="[% ui.header_image.width | html %]" />
        </a>
      </div>
      [% END %]
    </div>
  </div>

  <div class="toolbar">
    <span><strong>Mode:</strong> [% source.mode | html %]</span>
    <span class="right"><strong>Download base:</strong>
      [% IF ui.links_enabled && source.base_url %]
        <a href="[% source.base_url | html %]">[% source.base_url | html %]</a>
      [% ELSE %]
        <code>[% source.base_url | html %]</code>
      [% END %]
    </span>
  </div>

  <div class="health-hero">
    <div class="health-hero-head">Run health at a glance</div>
    <div class="health-banner">
      [% IF health.overall_class == 'bad' %]
        <span class="badge badge-bad">Attention needed</span>
      [% ELSIF health.overall_class == 'warn' %]
        <span class="badge badge-warn">Review recommended</span>
      [% ELSE %]
        <span class="badge badge-ok">Looks healthy</span>
      [% END %]
      <span class="badge">Expected published: [% health.expected_coverage_pct %]%</span>
      <span class="badge [% IF health.missing_expected_count %]badge-bad[% ELSE %]badge-ok[% END %]">Missing expected: [% health.missing_expected_count %]</span>
      <span class="badge [% IF health.record_check_mismatch_count %]badge-bad[% ELSE %]badge-ok[% END %]">NetCDF mismatches: [% health.record_check_mismatch_count %]</span>
      <span class="badge [% IF health.record_check_unknown_count %]badge-warn[% ELSE %]badge-ok[% END %]">NetCDF unknown: [% health.record_check_unknown_count %]</span>
      <span class="badge [% IF health.unexpected_output_count %]badge-warn[% ELSE %]badge-ok[% END %]">Unexpected published: [% health.unexpected_output_count %]</span>
      [% IF health.scenario.present %]
        <span class="badge [% IF health.scenario.class == 'ok' %]badge-ok[% ELSIF health.scenario.class == 'warn' %]badge-warn[% ELSIF health.scenario.class == 'bad' %]badge-bad[% ELSE %]badge-neutral[% END %]">Scenario status: [% health.scenario.label | html %]</span>
      [% ELSE %]
        <span class="badge badge-neutral">Scenario status: unavailable</span>
      [% END %]
      [% IF job_metrics.job_count %]
        <span class="badge">Jobs: [% job_metrics.job_count %]</span>
        <span class="badge [% IF job_metrics.queue_warning_count %]badge-warn[% ELSE %]badge-ok[% END %]">Queue delays >60s: [% job_metrics.queue_warning_count %]</span>
        [% IF job_metrics.workflow_span_human %]<span class="badge">Workflow span: [% job_metrics.workflow_span_human | html %]</span>[% END %]
      [% END %]
    </div>

    <div class="section-body">
      <div class="summary-grid">
        <div class="summary-card"><h3>Publication</h3><div class="body">
          <span class="badge">Expected outputs: [% totals.expected_output_count %]</span>
          <span class="badge badge-ok">Published expected: [% totals.published_expected_count %]</span>
          <span class="badge [% IF totals.missing_expected_count %]badge-bad[% ELSE %]badge-ok[% END %]">Missing expected: [% totals.missing_expected_count %]</span>
          <span class="badge [% IF totals.unexpected_output_count %]badge-warn[% ELSE %]badge-ok[% END %]">Unexpected published: [% totals.unexpected_output_count %]</span>
        </div></div>

        <div class="summary-card"><h3>NetCDF validation</h3><div class="body">
          <span class="badge badge-ok">OK: [% totals.record_check_ok_count %]</span>
          <span class="badge [% IF totals.record_check_mismatch_count %]badge-bad[% ELSE %]badge-ok[% END %]">Mismatch: [% totals.record_check_mismatch_count %]</span>
          <span class="badge [% IF totals.record_check_unknown_count %]badge-warn[% ELSE %]badge-ok[% END %]">Unknown: [% totals.record_check_unknown_count %]</span>
          <span class="badge">Summed records: [% totals.netcdf_record_total %]</span>
        </div></div>

        <div class="summary-card"><h3>Run metadata</h3><div class="body">
          <span class="badge [% IF health.has_run_props %]badge-ok[% ELSE %]badge-bad[% END %]">run.properties</span>
          <span class="badge [% IF health.has_fort14 %]badge-ok[% ELSE %]badge-warn[% END %]">fort.14</span>
          <span class="badge [% IF health.has_fort15 %]badge-ok[% ELSE %]badge-warn[% END %]">fort.15</span>
          <span class="badge [% IF health.has_buildinfo %]badge-ok[% ELSE %]badge-neutral[% END %]">build metadata</span>
          <span class="badge [% IF scenario_status_summary.present %]badge-ok[% ELSE %]badge-neutral[% END %]">scenario.status.json</span>
        </div></div>

        <div class="summary-card"><h3>Scenario status</h3><div class="body">
          [% IF scenario_status_summary.present %]
            <span class="badge [% IF scenario_status_summary.class == 'ok' %]badge-ok[% ELSIF scenario_status_summary.class == 'warn' %]badge-warn[% ELSIF scenario_status_summary.class == 'bad' %]badge-bad[% ELSE %]badge-neutral[% END %]">[% scenario_status_summary.label | html %]</span>
            [% FOREACH pair IN scenario_status_summary.scalar_pairs %]
              [% LAST IF loop.count > 5 %]
              <div class="small"><strong>[% pair.key | html %]:</strong> [% pair.value | html %]</div>
            [% END %]
          [% ELSE %]
            <span class="muted">No scenario status file was published for this run.</span>
          [% END %]
        </div></div>

        [% IF job_metrics.job_count %]
        <div class="summary-card"><h3>HPC jobs</h3><div class="body">
          <span class="badge">Count: [% job_metrics.job_count %]</span>
          [% IF job_metrics.longest_run_human %]
            <span class="badge badge-ok">Longest run: [% job_metrics.longest_run_human | html %]</span>
            <div class="small"><strong>Job:</strong> [% job_metrics.longest_run_jobid | html %] [% job_metrics.longest_run_jobtype | html %]</div>
          [% END %]
          [% IF job_metrics.longest_wait_human %]
            <span class="badge [% IF job_metrics.longest_wait_seconds > 60 %]badge-warn[% ELSE %]badge-ok[% END %]">Longest wait: [% job_metrics.longest_wait_human | html %]</span>
            <div class="small"><strong>Job:</strong> [% job_metrics.longest_wait_jobid | html %] [% job_metrics.longest_wait_jobtype | html %]</div>
          [% END %]
        </div></div>
        [% END %]
      </div>
    </div>
  </div>

  <div class="section"><h2>Source</h2><div class="section-body">
    <table class="info">
      <tr><th>SSH host</th><td><code>[% source.ssh_host | html %]</code></td></tr>
      <tr><th>Remote path</th><td><code>[% source.remote_path | html %]</code></td></tr>
      [% IF source.local_dir %]<tr><th>Local dir</th><td><code>[% source.local_dir | html %]</code></td></tr>[% END %]
      <tr><th>Download base</th><td>
        [% IF ui.links_enabled && source.base_url %]
          <a href="[% source.base_url | html %]">[% source.base_url | html %]</a>
        [% ELSE %]
          <code>[% source.base_url | html %]</code>
        [% END %]
      </td></tr>
      <tr><th>Deploy target</th><td><code>[% source.deploy_target | html %]</code></td></tr>
    </table>
  </div></div>

  <div class="section"><h2>Navigation</h2><div class="section-body">
    <div class="jump-links">
      <a href="#inventory-summary">Inventory summary</a>
      <a href="#expected-output-summary">Expected output summary</a>
      <a href="#record-check-summary">NetCDF record checks</a>
      <a href="#run-summary">Run summary</a>
      <a href="#scenario-status-summary">Scenario status</a>
      <a href="#hpc-job-timing">HPC job timing</a>
      <a href="#fort14-summary">fort.14</a>
      <a href="#fort15-summary">fort.15</a>
      <a href="#asgs-config-summary">ASGS config</a>
      <a href="#build-metadata">Build metadata</a>
      <a href="#adcirc-input-files">ADCIRC input files</a>
      <a href="#adcirc-output-files">ADCIRC output files</a>
      <a href="#other-files">Other files</a>
    </div>

    [% IF grouped.adcirc_output.size %]
    <div style="margin-top:8px;">
      <div class="legend">
        <div><span class="label">NetCDF quick jump legend:</span></div>
        <div style="margin-top:4px;"><span class="badge badge-ok">OK</span> expected record count matched actual local NetCDF record count</div>
        <div style="margin-top:4px;"><span class="badge badge-bad">Mismatch</span> expected record count did not match actual local NetCDF record count</div>
        <div style="margin-top:4px;"><span class="badge badge-neutral">Unknown</span> expected count exists, but no usable local NetCDF metadata was available</div>
      </div>
      <div class="small" style="margin-bottom:5px;"><strong>NetCDF quick jump</strong></div>
      <div class="netcdf-pills">
        [% FOREACH f IN grouped.adcirc_output %]
          [% css_class = '' %]
          [% IF f.record_check == 'ok' %][% css_class = 'ok' %]
          [% ELSIF f.record_check == 'mismatch' %][% css_class = 'mismatch' %]
          [% ELSIF f.record_check == 'unknown' %][% css_class = 'unknown' %]
          [% END %]
          <a class="[% css_class %]" href="#nc-[% f.name | replace('.', '-') | replace('/', '-') | html %]">[% f.name | html %][% IF f.record_check == 'ok' %] ✓[% END %][% IF f.record_check == 'mismatch' %] ✕[% END %][% IF f.record_check == 'unknown' %] ?[% END %]</a>
        [% END %]
      </div>
    </div>
    [% END %]
  </div></div>

  <div class="section anchor-offset" id="inventory-summary"><h2>Inventory summary</h2><div class="section-body">
    <div class="legend">
      <div><span class="label">How to read this page:</span></div>
      <div style="margin-top:4px;"><span class="badge">Expected outputs: [% totals.expected_output_count %]</span> Count of filenames explicitly declared in <code>run.properties</code>, usually by <code>adcirc.file.output.&lt;name&gt;.*</code> keys such as <code>.numdatasets</code>, <code>.enable</code>, <code>.format</code>, or <code>.name</code>.</div>
      <div style="margin-top:4px;"><span class="badge badge-ok">Published expected: [% totals.published_expected_count %]</span> Files that were both declared in <code>run.properties</code> and found in the published directory.</div>
      <div style="margin-top:4px;"><span class="badge badge-bad">Missing expected: [% totals.missing_expected_count %]</span> Files declared in <code>run.properties</code> that were not found in the published directory.</div>
      <div style="margin-top:4px;"><span class="badge badge-warn">Unexpected published: [% totals.unexpected_output_count %]</span> Files found in the published directory that were not explicitly declared as ADCIRC outputs in <code>run.properties</code>.</div>
      <div style="margin-top:4px;"><span class="badge badge-ok">OK</span> The file has an expected record count from <code>run.properties</code> and the actual NetCDF record count matched when inspected locally.</div>
      <div style="margin-top:4px;"><span class="badge badge-bad">Mismatch</span> The file has an expected record count from <code>run.properties</code>, but the actual NetCDF record count did not match.</div>
      <div style="margin-top:4px;"><span class="badge badge-neutral">Unknown</span> A comparison could not be completed, usually because an expected count exists but local NetCDF metadata was unavailable or could not be parsed.</div>
      <div style="margin-top:4px;" class="muted">Expected-ness comes from <code>run.properties</code>. Presence comes from the published directory. Record checks come from local NetCDF inspection when a local file is available.</div>
    </div>

    <div class="summary-grid">
      <div class="summary-card"><h3>Inventory</h3><div class="body"><span class="badge">Files: [% totals.file_count %]</span><span class="badge">NetCDF: [% totals.netcdf_count %]</span><span class="badge">Total size: [% totals.bytes_total_human %]</span></div></div>
      <div class="summary-card"><h3>Breakdown</h3><div class="body"><span class="badge">Input: [% totals.input_count %]</span><span class="badge">Output: [% totals.output_count %]</span><span class="badge">Other: [% totals.other_count %]</span></div></div>
      <div class="summary-card"><h3>NetCDF checks</h3><div class="body"><span class="badge badge-ok">OK: [% totals.record_check_ok_count %]</span><span class="badge badge-bad">Mismatch: [% totals.record_check_mismatch_count %]</span><span class="badge badge-neutral">Unknown: [% totals.record_check_unknown_count %]</span><span class="badge">Summed records: [% totals.netcdf_record_total %]</span></div></div>
      <div class="summary-card"><h3>Expected output tracking</h3><div class="body">
        <span class="badge">Expected outputs: [% totals.expected_output_count %]</span>
        <span class="badge badge-ok">Published expected: [% totals.published_expected_count %]</span>
        <span class="badge [% IF totals.missing_expected_count %]badge-bad[% ELSE %]badge-ok[% END %]">Missing expected: [% totals.missing_expected_count %]</span>
        <span class="badge [% IF totals.unexpected_output_count %]badge-warn[% ELSE %]badge-ok[% END %]">Unexpected published: [% totals.unexpected_output_count %]</span>
        <div class="small muted" style="margin-top:6px;">Expected-ness comes from <code>run.properties</code>; presence comes from the published directory listing.</div>
      </div></div>
    </div>
  </div></div>

  <div class="section anchor-offset" id="expected-output-summary"><h2>Expected output summary</h2><div class="section-body">
    <div class="legend">
      <div><span class="label">Why files appear in this section:</span></div>
      <div style="margin-top:4px;"><span class="badge">Expected outputs</span> Files explicitly declared in <code>run.properties</code>, usually by <code>adcirc.file.output.&lt;name&gt;.*</code> keys.</div>
      <div style="margin-top:4px;"><span class="badge badge-bad">Missing expected</span> Declared in <code>run.properties</code> but not present in the published directory.</div>
      <div style="margin-top:4px;"><span class="badge badge-warn">Published but not explicitly declared</span> Present in the published directory but not explicitly declared as an ADCIRC output in <code>run.properties</code>.</div>
    </div>

    [% IF expected_outputs.size %]
    <details><summary>Show expected output filenames from <code>run.properties</code> ([% expected_outputs.size %])</summary><pre>[% FOREACH name IN expected_outputs %][% name | html %]
[% END %]</pre></details>
    [% END %]

    [% IF missing_expected.size %]
    <h3 class="bad" style="margin:10px 0 6px 0;">Missing expected outputs</h3>
    <table class="listing"><thead><tr><th>Expected file</th><th class="compact-col-md">Expected records</th><th>Reason</th></tr></thead><tbody>
    [% FOREACH item IN missing_expected %]
      <tr><td><code>[% item.name | html %]</code></td><td>[% item.expected_records || '' %]</td><td>[% item.reason | html %]</td></tr>
    [% END %]
    </tbody></table>
    [% ELSE %]
    <div class="good">No expected outputs are missing from the published directory.</div>
    [% END %]

    [% IF unexpected_outputs.size %]
    <h3 class="warn" style="margin:10px 0 6px 0;">Published outputs not explicitly declared in <code>run.properties</code></h3>
    <table class="listing"><thead><tr><th>Published file</th><th class="compact-col-md">Size</th><th class="compact-col-date">Modified</th><th class="compact-col-sm">Download</th></tr></thead><tbody>
    [% FOREACH f IN unexpected_outputs %]
      <tr><td><code>[% f.name | html %]</code></td><td>[% f.size_human | html %]</td><td>[% f.mtime_iso | html %]</td><td>[% IF f.url %]<a href="[% f.url | html %]">download</a>[% ELSE %]<span class="muted">disabled</span>[% END %]</td></tr>
    [% END %]
    </tbody></table>
    [% END %]
  </div></div>

  [% IF record_mismatches.size || record_unknown.size %]
  <div class="section anchor-offset" id="record-check-summary"><h2>NetCDF record checks</h2><div class="section-body">
    <div class="legend">
      <div><span class="label">Why a check lands here:</span></div>
      <div style="margin-top:4px;"><span class="badge badge-bad">Mismatch</span> The file has an expected record count from <code>run.properties</code>, but the actual NetCDF record count did not match.</div>
      <div style="margin-top:4px;"><span class="badge badge-neutral">Unknown</span> An expected count exists, but the actual record count could not be confirmed from local NetCDF metadata.</div>
    </div>

    [% IF record_mismatches.size %]
    <h3 class="bad" style="margin:0 0 6px 0;">Mismatches</h3>
    <table class="listing"><thead><tr><th>File</th><th class="compact-col-sm">Actual</th><th class="compact-col-md">Expected</th><th class="compact-col-sm">Download</th></tr></thead><tbody>
    [% FOREACH f IN record_mismatches %]
      <tr><td><code>[% f.name | html %]</code></td><td>[% IF f.nc && !f.nc.error %][% f.nc.record_count || '' %][% ELSE %]error[% END %]</td><td>[% f.expected_records || '' %]</td><td>[% IF f.url %]<a href="[% f.url | html %]">download</a>[% ELSE %]<span class="muted">disabled</span>[% END %]</td></tr>
    [% END %]
    </tbody></table>
    [% END %]

    [% IF record_unknown.size %]
    <h3 class="warn" style="margin:10px 0 6px 0;">Unknown checks</h3>
    <table class="listing"><thead><tr><th>File</th><th>Reason</th><th class="compact-col-sm">Download</th></tr></thead><tbody>
    [% FOREACH f IN record_unknown %]
      <tr>
        <td><code>[% f.name | html %]</code></td>
        <td>[% IF f.nc && f.nc.error %]<details><summary>ncdump error</summary><pre>[% f.nc.error | html %]</pre></details>[% ELSE %]expected count exists, actual record count unavailable[% END %]</td>
        <td>[% IF f.url %]<a href="[% f.url | html %]">download</a>[% ELSE %]<span class="muted">disabled</span>[% END %]</td>
      </tr>
    [% END %]
    </tbody></table>
    [% END %]
  </div></div>
  [% END %]

  [% IF run_properties.key_count %]
  <div class="section anchor-offset" id="run-summary"><h2>Run summary</h2><div class="section-body">
    <table class="info">
      [% FOREACH k IN run_properties.summary.keys.sort %]
      <tr><th><code>[% k | html %]</code></th><td>[% run_properties.summary.$k | html %]</td></tr>
      [% END %]
    </table>
    [% IF run_properties.output_keys.size %]
    <details><summary>Show all <code>adcirc.file.output.*</code> keys from <code>run.properties</code></summary><pre>[% FOREACH k IN run_properties.output_keys %][% k | html %] = [% run_properties.all_keys_anon.$k | html %]
[% END %]</pre></details>
    [% END %]
  </div></div>
  [% END %]

  [% IF scenario_status_summary.present %]
  <div class="section anchor-offset" id="scenario-status-summary"><h2>scenario.status.json summary</h2><div class="section-body">
    <div style="margin-bottom:8px;"><span class="badge [% IF scenario_status_summary.class == 'ok' %]badge-ok[% ELSIF scenario_status_summary.class == 'warn' %]badge-warn[% ELSIF scenario_status_summary.class == 'bad' %]badge-bad[% ELSE %]badge-neutral[% END %]">[% scenario_status_summary.label | html %]</span></div>
    [% IF scenario_status_summary.error %]<pre>[% scenario_status_summary.error | html %]</pre>[% END %]
    [% IF scenario_status_summary.scalar_pairs.size %]
    <table class="info">
      [% FOREACH pair IN scenario_status_summary.scalar_pairs %]
      <tr><th><code>[% pair.key | html %]</code></th><td>[% pair.value | html %]</td></tr>
      [% END %]
    </table>
    [% END %]
    [% IF scenario_status_json %]
    <details><summary>Show raw parsed scenario status structure</summary><pre>[% scenario_status_json | html %]</pre></details>
    [% END %]
  </div></div>
  [% END %]

  [% IF job_durations && job_durations.size %]
  <div class="section anchor-offset" id="hpc-job-timing"><h2>HPC job timing</h2><div class="section-body">
    <div class="legend">
      <div><span class="label">How durations are computed:</span></div>
      <div style="margin-top:4px;"><span class="badge">Queue wait</span> <code>time.start - time.submit</code></div>
      <div style="margin-top:4px;"><span class="badge badge-ok">Run time</span> <code>time.finish - time.start</code></div>
      <div style="margin-top:4px;"><span class="badge">Total</span> <code>time.finish - time.submit</code></div>
      <div style="margin-top:4px;" class="muted">Missing timestamps remain <code>n/a</code>. This section handles any number of entries in <code>jobs.status[]</code>.</div>
    </div>

    <div class="summary-grid" style="margin-bottom:8px;">
      <div class="summary-card"><h3>HPC job summary</h3><div class="body">
        <span class="badge">Jobs: [% job_metrics.job_count %]</span>
        [% IF job_metrics.workflow_span_human %]<span class="badge">Workflow span: [% job_metrics.workflow_span_human | html %]</span>[% END %]
        [% IF job_metrics.sum_run_human %]<span class="badge badge-ok">Summed run: [% job_metrics.sum_run_human | html %]</span>[% END %]
        [% IF job_metrics.sum_total_human %]<span class="badge">Summed total: [% job_metrics.sum_total_human | html %]</span>[% END %]
      </div></div>

      <div class="summary-card"><h3>Longest intervals</h3><div class="body">
        [% IF job_metrics.longest_run_human %]
          <span class="badge badge-ok">Longest run: [% job_metrics.longest_run_human | html %]</span>
          <div class="small"><strong>Job:</strong> [% job_metrics.longest_run_jobid | html %] [% job_metrics.longest_run_jobtype | html %]</div>
        [% END %]
        [% IF job_metrics.longest_wait_human %]
          <span class="badge [% IF job_metrics.longest_wait_seconds > 60 %]badge-warn[% ELSE %]badge-ok[% END %]">Longest wait: [% job_metrics.longest_wait_human | html %]</span>
          <div class="small"><strong>Job:</strong> [% job_metrics.longest_wait_jobid | html %] [% job_metrics.longest_wait_jobtype | html %]</div>
        [% END %]
      </div></div>
    </div>

    <table class="listing">
      <thead><tr><th class="compact-col-md">Job ID</th><th>Type</th><th class="compact-col-date">Submit</th><th class="compact-col-date">Start</th><th class="compact-col-date">Finish</th><th class="compact-col-md">Queue wait</th><th class="compact-col-md">Run time</th><th class="compact-col-md">Total</th></tr></thead>
      <tbody>
      [% FOREACH j IN job_durations %]
        <tr>
          <td><code>[% j.jobid | html %]</code></td>
          <td>[% j.jobtype | html %][% IF j.error %]<div class="small bad">error: [% j.error | html %]</div>[% END %]</td>
          <td>[% j.submit | html %]</td>
          <td>[% j.start | html %]</td>
          <td>[% j.finish | html %]</td>
          <td>[% IF j.wait_seconds.defined %]<span class="badge [% IF j.wait_seconds > 60 %]badge-warn[% ELSE %]badge-ok[% END %]">[% j.wait_human | html %]</span>[% ELSE %]<span class="muted">n/a</span>[% END %]</td>
          <td>[% IF j.run_seconds.defined %]<span class="badge badge-ok">[% j.run_human | html %]</span>[% ELSE %]<span class="muted">n/a</span>[% END %]</td>
          <td>[% IF j.total_seconds.defined %]<span class="badge">[% j.total_human | html %]</span>[% ELSE %]<span class="muted">n/a</span>[% END %]</td>
        </tr>
      [% END %]
      </tbody>
    </table>
  </div></div>
  [% END %]

  [% IF fort14.title || fort14.raw_header2 %]
  <div class="section anchor-offset" id="fort14-summary"><h2>fort.14 summary</h2><div class="section-body">
    <table class="info">
      <tr><th>Title</th><td>[% fort14.title | html %]</td></tr>
      <tr><th>Header line 2</th><td><code>[% fort14.raw_header2 | html %]</code></td></tr>
      [% IF fort14.ne || fort14.np %]
      <tr><th>Mesh counts</th><td><span class="badge">Elements: [% fort14.ne %]</span><span class="badge">Nodes: [% fort14.np %]</span></td></tr>
      [% END %]
    </table>
  </div></div>
  [% END %]

  [% IF fort15.line_count %]
  <div class="section anchor-offset" id="fort15-summary"><h2>fort.15 summary</h2><div class="section-body">
    <table class="info"><tr><th>Line count</th><td>[% fort15.line_count %]</td></tr></table>
    [% IF fort15.preview_lines.size %]
    <details open><summary>Preview</summary><pre>[% FOREACH line IN fort15.preview_lines %][% line | html %]
[% END %]</pre></details>
    [% END %]
  </div></div>
  [% END %]

  [% IF asgs_config.filename %]
  <div class="section anchor-offset" id="asgs-config-summary"><h2>ASGS config summary</h2><div class="section-body">
    <table class="info"><tr><th>Config file</th><td><code>[% asgs_config.filename | html %]</code></td></tr></table>
    [% IF asgs_config.summary.keys.size %]
    <table class="info" style="margin-top:8px;">
      [% FOREACH k IN asgs_config.summary.keys.sort %]
      <tr><th><code>[% k | html %]</code></th><td>[% asgs_config.summary.$k | html %]</td></tr>
      [% END %]
    </table>
    [% END %]
    [% IF asgs_config.preview.size %]
    <details><summary>Preview</summary><pre>[% FOREACH line IN asgs_config.preview %][% line | html %]
[% END %]</pre></details>
    [% END %]
  </div></div>
  [% END %]

  [% IF buildinfo && buildinfo.keys.size %]
  <div class="section anchor-offset" id="build-metadata"><h2>ADCIRC build metadata [% IF buildinfo_name %]<span class="small muted">(<code>[% buildinfo_name | html %]</code>)</span>[% END %]</h2><div class="section-body">
    [% build_stages = buildinfo.item('adcirc.build.actualflags.info') %]
    [% applied_patches = buildinfo.item('adcirc.source.asgs.patches.applied') %]

    <table class="info" style="margin-bottom:8px;">
      [% FOREACH k IN [
           'adcirc.source.commit','adcirc.source.branch-base','adcirc.source.asgs.adcirc.flavor','adcirc.source.asgs.patches.set',
           'env.adcirc.build.ADCIRC_GIT_URL','env.adcirc.build.ADCIRC_GIT_REPO','env.adcirc.build.ADCIRC_COMPILER',
           'adcirc.build.fortran.compiler','adcirc.build.c.compiler','adcirc.build.built_parallel_adcirc','adcirc.build.debug',
           'env.adcirc.build.ADCIRC_PROFILE_NAME','adcirc.singularity.sif','adcirc.singularity.manifest','asgs.container.cmd'
         ] %]
        [% IF buildinfo.exists(k) %]
        <tr><th><code>[% k | html %]</code></th><td>[% v = buildinfo.item(k) %][% IF v %][% v | html %][% ELSE %]<span class="muted">(not set)</span>[% END %]</td></tr>
        [% END %]
      [% END %]
    </table>

    [% IF applied_patches && applied_patches.size %]
    <h3 style="margin:10px 0 6px 0;">Applied patches</h3>
    <div class="legend"><div><span class="label">Why this appears:</span></div><div style="margin-top:4px;">This list comes from <code>adcirc.source.asgs.patches.applied</code> in the ADCIRC build JSON. Each entry is a patch file that was recorded as applied during the build.</div></div>
    <table class="listing"><thead><tr><th>#</th><th>Patch file</th></tr></thead><tbody>
    [% FOREACH p IN applied_patches %]
      <tr><td class="compact-col-xs">[% loop.count %]</td><td><code>[% p | html %]</code></td></tr>
    [% END %]
    </tbody></table>
    [% ELSIF buildinfo.exists('adcirc.source.asgs.patches.applied') %]
    <h3 style="margin:10px 0 6px 0;">Applied patches</h3><div class="muted">No patch filenames were recorded in <code>adcirc.source.asgs.patches.applied</code>.</div>
    [% END %]

    [% IF build_stages && build_stages.size %]
    <h3 style="margin:10px 0 6px 0;">Build stages</h3>
    <table class="listing"><thead><tr><th>Stage</th><th class="compact-col-lg">Compiler</th><th class="compact-col-date">Datestamp</th></tr></thead><tbody>
    [% FOREACH item IN build_stages %]
      <tr><td>[% item.stage | html %]</td><td>[% item.compiler | html %]</td><td>[% item.datestamp | html %]</td></tr>
    [% END %]
    </tbody></table>
    [% END %]

    <table class="info" style="margin-top:10px;">
      [% FOREACH k IN buildinfo.keys.sort %]
        [% NEXT IF k == "adcirc.build.actualflags.info" %]
        [% NEXT IF k == "adcirc.source.asgs.patches.applied" %]
        <tr>
          <th><code>[% k | html %]</code></th>
          <td>
            [% v = buildinfo.item(k) %]
            [% IF v.search('^ARRAY\\(') %]
              <details><summary>array value</summary><ul class="compact-list">[% FOREACH item IN buildinfo.item(k) %]<li><code>[% item | html %]</code></li>[% END %]</ul></details>
            [% ELSIF v.search('^HASH\\(') %]
              <details><summary>structured value</summary><table class="info" style="margin-top:6px;">[% FOREACH hk IN buildinfo.item(k).keys.sort %]<tr><th><code>[% hk | html %]</code></th><td>[% hv = buildinfo.item(k).item(hk) %][% IF hv.search('^(HASH|ARRAY)\\(') %]<span class="muted">nested structured value</span>[% ELSE %][% hv | html %][% END %]</td></tr>[% END %]</table></details>
            [% ELSE %]
              [% IF (k == 'adcirc.singularity.sif' && !v) || (k == 'adcirc.singularity.manifest' && !v) || (k == 'asgs.container.cmd' && !v) %]
                <span class="muted">(not set)</span>
              [% ELSE %]
                [% v | html %]
              [% END %]
            [% END %]
          </td>
        </tr>
      [% END %]
    </table>
  </div></div>
  [% END %]

  <div class="section anchor-offset" id="adcirc-input-files"><h2>ADCIRC input files</h2><div class="section-body" style="padding:0;">
    <table class="listing"><thead><tr><th>Name</th><th class="compact-col-md">Size</th><th class="compact-col-date">Modified</th><th class="compact-col-sm">Download</th></tr></thead><tbody>
    [% FOREACH f IN grouped.adcirc_input %]
      <tr><td><code>[% f.name | html %]</code></td><td>[% f.size_human | html %]</td><td>[% f.mtime_iso | html %]</td><td>[% IF f.url %]<a href="[% f.url | html %]">download</a>[% ELSE %]<span class="muted">disabled</span>[% END %]</td></tr>
    [% END %]
    </tbody></table>
  </div></div>

  <div class="section anchor-offset" id="adcirc-output-files"><h2>ADCIRC output files</h2><div class="section-body" style="padding:0;">
    <div style="padding:8px 10px 0 10px;">
      <div class="legend">
        <div><span class="label">Output file legend:</span></div>
        <div style="margin-top:4px;"><span class="badge badge-ok">expected</span> declared in <code>run.properties</code> as an expected ADCIRC output</div>
        <div style="margin-top:4px;"><span class="badge badge-warn">published-only</span> found in the published directory but not explicitly declared in <code>run.properties</code></div>
        <div style="margin-top:4px;"><span class="badge badge-ok">OK</span> expected record count matched actual local NetCDF record count</div>
        <div style="margin-top:4px;"><span class="badge badge-bad">Mismatch</span> expected record count did not match actual local NetCDF record count</div>
        <div style="margin-top:4px;"><span class="badge badge-neutral">Unknown</span> no completed record comparison was possible</div>
      </div>
    </div>

    <table class="listing"><thead><tr><th>Name</th><th class="compact-col-sm">Expected</th><th class="compact-col-md">Size</th><th class="compact-col-date">Modified</th><th class="compact-col-sm">Actual</th><th class="compact-col-md">Expected recs</th><th class="compact-col-md">Check</th><th class="compact-col-xs">Dims</th><th class="compact-col-xs">Vars</th><th class="compact-col-sm">Download</th></tr></thead><tbody>
    [% FOREACH f IN grouped.adcirc_output %]
      <tr>
        <td class="file-name-cell" id="nc-[% f.name | replace('.', '-') | replace('/', '-') | html %]">
          <span class="file-name-main"><code>[% f.name | html %]</code></span>
          <span class="file-badge-row">
            [% IF f.is_expected_output %]<span class="badge badge-ok">expected</span>[% ELSE %]<span class="badge badge-warn">published-only</span>[% END %]
            [% IF f.record_check == 'ok' %]<span class="badge badge-ok">OK</span>[% ELSIF f.record_check == 'mismatch' %]<span class="badge badge-bad">Mismatch</span>[% ELSIF f.record_check == 'unknown' %]<span class="badge badge-neutral">Unknown</span>[% END %]
          </span>
          [% IF f.nc && f.nc.error %]<details class="meta-toggle"><summary>metadata error</summary><pre>[% f.nc.error | html %]</pre></details>[% END %]
        </td>
        <td>[% IF f.is_expected_output %]<span class="good">yes</span>[% ELSE %]<span class="warn">no</span>[% END %]</td>
        <td>[% f.size_human | html %]</td>
        <td>[% f.mtime_iso | html %]</td>
        <td>[% IF f.nc && !f.nc.error %][% f.nc.record_count || '' %][% ELSIF f.nc && f.nc.error %]<span class="bad">error</span>[% END %]</td>
        <td>[% f.expected_records || '' %]</td>
        <td>[% IF f.record_check == 'ok' %]<span class="good">OK</span>[% ELSIF f.record_check == 'mismatch' %]<span class="bad">Mismatch</span>[% ELSIF f.record_check == 'unknown' %]<span class="warn">Unknown</span>[% END %]</td>
        <td>[% IF f.nc && !f.nc.error %][% f.nc.dimension_count %][% END %]</td>
        <td>[% IF f.nc && !f.nc.error %][% f.nc.variable_count %][% END %]</td>
        <td>[% IF f.url %]<a href="[% f.url | html %]">download</a>[% ELSE %]<span class="muted">disabled</span>[% END %]</td>
      </tr>
    [% END %]
    </tbody></table>
  </div></div>

  [% IF grouped.other.size %]
  <div class="section anchor-offset" id="other-files"><h2>Other files</h2><div class="section-body" style="padding:0;">
    <table class="listing"><thead><tr><th>Name</th><th class="compact-col-md">Size</th><th class="compact-col-date">Modified</th><th class="compact-col-sm">Download</th></tr></thead><tbody>
    [% FOREACH f IN grouped.other %]
      <tr><td><code>[% f.name | html %]</code></td><td>[% f.size_human | html %]</td><td>[% f.mtime_iso | html %]</td><td>[% IF f.url %]<a href="[% f.url | html %]">download</a>[% ELSE %]<span class="muted">disabled</span>[% END %]</td></tr>
    [% END %]
    </tbody></table>
  </div></div>
  [% END %]

  <div class="footer-note">This page intentionally borrows the visual feel of a traditional <code>phpinfo()</code> report: blue section headers, compact system-style tables, and dense at-a-glance diagnostics.</div>
</div>
</body>
</html>
