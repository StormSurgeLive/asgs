THIS=$(basename -- $0)

if [ -z "$_ASGSH_PID" ]; then
  echo "This script is meant to run inside of the ASGS Shell Environment, asgsh."
  exit 1;
fi

_getScenarioPackageSize() {
  si=0
  while [ 1 ]; do
    SCENARIO="null"
    ENSTORM="null"  # ENSTORM is deprecated, older config files used this
    # maintain backward compatibility with old config files
    SCENARIOPACKAGESIZE=-1
    ENSEMBLESIZE=-1
    source $ASGS_CONFIG
    if [[ $ENSEMBLESIZE -ne -1 ]]; then
      SCENARIOPACKAGESIZE=$ENSEMBLESIZE   # ENSEMBLESIZE is deprecated
    fi
    if [[ $ENSTORM != "null" ]]; then
      SCENARIO=$ENSTORM                   # ENSTORM is deprecated
    fi
    if [[ $SCENARIO == "null" ]]; then
      logMessage "$THIS: There are '$si' scenarios in the scenario package."
      break
    fi
    ((si++))
  done

  echo $si

}

_getScenarioPackageSize $@