# START ASGS "init" completion
# This file is in the public domain

_asgsinit_completion()
{
    local cur prev
    COMPREPLY=()

    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    case "$prev" in
        config|keys)
            # no further completion after subcommand
            return 0
            ;;
        *)
            COMPREPLY=( $(compgen -W "config keys" -- "$cur") )
            ;;
    esac

    return 0
}

complete -o default -F _asgsinit_completion init

# END init completion
